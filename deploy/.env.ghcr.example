# GHCR image tag to deploy.
# `edge` tracks the latest default-branch image.
# Release tags are published without the leading `v`, for example `1.2.3`.
IMAGE_REPOSITORY=ghcr.io/sxmxc/urban-octo-bassoon
IMAGE_TAG=edge

# Published host ports
API_PUBLISHED_PORT=8000
ADMIN_WEB_PUBLISHED_PORT=3000

# Database
POSTGRES_USER=mockadmin
POSTGRES_PASSWORD=change-me
POSTGRES_DB=mockapi
POSTGRES_VOLUME_NAME=urban_octo_bassoon_pgdata

# Backend
API_LOG_LEVEL=info
ENABLE_OPENAPI=true

# Admin bootstrap
# Leave ADMIN_BOOTSTRAP_PASSWORD blank to have Mockingbird generate a one-time
# password and print it in the API logs on first bootstrap.
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_PASSWORD_MIN_LENGTH=12
ADMIN_SESSION_TTL_HOURS=12
ADMIN_REMEMBER_ME_TTL_DAYS=30
