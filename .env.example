# Database
POSTGRES_USER=mockadmin
POSTGRES_PASSWORD=mockpassword
POSTGRES_DB=mockapi
POSTGRES_VOLUME_NAME=urban_octo_bassoon_pgdata
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Backend
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info

# Admin bootstrap
# Leave ADMIN_BOOTSTRAP_PASSWORD blank to have Mockingbird generate a one-time password
# and print it in the API logs the first time the admin user is created.
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_PASSWORD_MIN_LENGTH=12
ADMIN_SESSION_TTL_HOURS=12
ADMIN_REMEMBER_ME_TTL_DAYS=30

# Frontend
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3000
FRONTEND_ALLOWED_HOSTS=localhost,127.0.0.1
FRONTEND_DEV_PROXY_TARGET=http://api:8000

# Runtime flags
ENABLE_OPENAPI=true
